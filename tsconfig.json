{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "App.tsx",
    "index.js",
    "src/**/*.ts",
    "src/**/*.tsx",
    "amplify/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "android",
    "ios",
    ".expo",
    ".amplify",
    "dist",
    "build",
    "coverage"
  ]
}
